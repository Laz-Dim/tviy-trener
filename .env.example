# Environment variables for tviy-trener
# Copy to .env and fill in your values

# YouTube Data API v3 key (get from Google Cloud Console)
YOUTUBE_API_KEY=your_youtube_api_key_here

# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Cloudflare Workers - set in Cloudflare dashboard instead:
# OTP_KV namespace binding
# TELEGRAM_BOT_TOKEN (for Workers)
# ADMIN_CHAT_ID (e.g., 5192950042)

# GitHub Personal Access Token (for GitHub Actions to push)
# GH_PAT=your_github_pat_here